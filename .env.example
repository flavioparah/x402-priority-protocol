# x402-shield environment — copy to .env and fill in.
# This file mirrors the minimal config OPERATOR-QUICKSTART.md uses by default.
# Production and advanced sections at the bottom are commented out — uncomment
# only what your deployment needs.

# ─── Minimal config (required for local dev / first paid request) ───────────

# REQUIRED: Solana wallet address that receives priority payments.
# Must be a valid base58-encoded public key on Solana.
PAYMENT_DESTINATION=YourSolanaWalletHere

# Upstream RPC node the Shield proxies to.
REAL_RPC_URL=https://api.mainnet-beta.solana.com

# Load at which 402 gating activates (0.0–1.0). Lower = more requests
# are gated. For a live demo set to 0 to force 402 on every request.
RPC_LOAD_THRESHOLD=0.75

# Per-IP rate limit before gating kicks in regardless of load.
REQUESTS_PER_IP_LIMIT=100
RATE_WINDOW_MS=60000

# Priority price bounds in micro-lamports. Price scales linearly with
# load between these two. Production defaults (Cenário 20×):
# BASE_PRICE = 20 lamports per priority request (floor under load)
# MAX_PRICE  = 1000 lamports per priority request (saturated load)
BASE_PRICE=20000
MAX_PRICE=1000000

# ─── Production config (recommended for serious deployments) ────────────────
# Uncomment as needed. All optional; Shield falls back to safe defaults if unset.

# Redis URL for multi-instance state durability. Without this, state is
# in-memory only and lost on restart. Strongly recommended in production.
#REDIS_URL=redis://localhost:6379

# Fail-fast on Redis disconnect instead of silent in-memory fallback.
# Set to "1" in production so a Redis outage is visible (HTTP 503) rather
# than masked as data loss.
#REDIS_REQUIRED=0

# Alternative spelling for REAL_RPC_URL — accepted by the same code path.
# Pick one (REAL_RPC_URL OR SOLANA_RPC_URL); if both set, REAL_RPC_URL wins.
#SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Global throughput ceiling (requests per second) across all clients.
# Acts as a hard backpressure point above any per-IP / per-pubkey limit.
#MAX_RPS=0

# Operator slug. Used in cross-operator attestations once the Shield is
# wired to a Trust-Score broker (Phase 2+ of the cross-op roadmap).
# Pick a stable identifier (e.g., "rpc-priority-us-east"). REQUIRED when
# TRUST_SCORE_BROKER_URL is set.
#OPERATOR_ID=

# Trust-Score broker URL (when broker is deployed). With this set, the
# Shield posts attestations cross-operator and queries cross-op reputation.
# Without it, the Shield uses local-only reputation.
#TRUST_SCORE_BROKER_URL=

# ─── Advanced QoS config (only tune if you understand the queue) ────────────

# Load below which the priority queue is bypassed entirely — every request
# fast-paths through. Default: equal to RPC_LOAD_THRESHOLD.
#QOS_BYPASS_THRESHOLD=0.65

# Max requests held in the priority queue. New paid requests above this
# get rejected with X-x402-Reason: queue-overflow.
#QOS_MAX_QUEUE_DEPTH=1000

# Max wait time in queue (ms) before a request is rejected with
# X-x402-Reason: queue-timeout.
#QOS_QUEUE_TIMEOUT_MS=5000

# Mode: "off" | "standalone" | "cooperative". Cooperative forwards
# X-Priority-Score header upstream for operators that implement the
# x402-qos-cooperative spec (docs/rfc/x402-qos-cooperative.md).
#QOS_MODE=standalone

# ─── Demo-only flags (NEVER set in production) ──────────────────────────────

# Force /health to report load_forced: true regardless of real RPC pressure.
# Used by trusted-deposit progression demos. Causes the 402 path to fire
# unconditionally. Remove before production traffic.
#RPC_LOAD_FORCE=

# Enable trusted (non-on-chain-verified) deposits. ONLY for trust-score
# progression demos. NEVER set in production — clients could declare
# arbitrary deposits without paying.
#ESCROW_TRUST_DEPOSITS=
