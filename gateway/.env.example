# x402-Shield Gateway — Exemplo de Configuração
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA faça commit do arquivo .env com dados reais.

# Porta do servidor
PORT=3000

# URL do nó RPC que você quer proteger (use Helius, Triton ou QuickNode em produção)
REAL_RPC_URL=https://api.mainnet-beta.solana.com

# Endereço da sua carteira Solana para receber pagamentos x402 (Base58)
PAYMENT_DESTINATION=SUA_CARTEIRA_AQUI

# Limiar de carga para ativar os desafios 402 (0.0 a 1.0)
RPC_LOAD_THRESHOLD=0.75

# Forçar carga para testes/demo (remova ou comente em produção real)
# RPC_LOAD_FORCE=0.9

# Limites de taxa por IP
REQUESTS_PER_IP_LIMIT=100
RATE_WINDOW_MS=60000

# Precificação (em micro-lamports)
BASE_PRICE=1000
MAX_PRICE=50000

# Redis (opcional para instância única, OBRIGATÓRIO para multi-instância)
# REDIS_URL=redis://localhost:6379

# Contexto de rede
SOLANA_NETWORK=mainnet
